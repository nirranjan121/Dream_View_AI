# Copy to .env and fill in real values before running

# Server
PORT=3000

# ─────────────────────────────────────────────────────────────────
# Core AI — required for design_modify and cost estimation
# Get a free key at https://aistudio.google.com/apikey
# ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────
# Cost Estimator Module (estimate_full_cost tool)
# ─────────────────────────────────────────────────────────────────

# Used to geocode free-text locations into lat/lng + city name.
# Get a key at https://console.cloud.google.com → Maps Geocoding API.
# OPTIONAL — if not set, Gemini is used as a fallback geocoder.
GOOGLE_MAPS_API_KEY=

# Legacy: web-search API key placeholder (e.g. Serper, Brave Search).
# NOT required — the cost estimator uses Gemini grounded search instead.
WEB_SEARCH_API_KEY=

# ─────────────────────────────────────────────────────────────────
# House Plan Vision (generate_3d_shell tool)
# ─────────────────────────────────────────────────────────────────

# Optional: swap in a real vision/segmentation backend later.
# For the MVP, generate_3d_shell uses a stub extractor (see houseplan.vision.ts).
VISION_MODEL_ENDPOINT=
